# Repo API token (recommended for build — avoids HTTP 403 rate limits)
# Create: https://github.com/settings/tokens — scope "public_repo" (classic) or read access to public repos (fine-grained)
REPO_API_TOKEN=

# Web3Forms contact form — https://web3forms.com (safe to expose in the client bundle)
PUBLIC_WEB3FORMS_ACCESS_KEY=

# GitHub Pages (optional local override; CI sets these for https://darkmoonight.github.io/)
# ASTRO_SITE=https://darkmoonight.github.io
# ASTRO_BASE=/